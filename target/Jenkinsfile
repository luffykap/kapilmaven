Pipeline{
	agent any
	
	tools{
		jdk : 'JDK'
		maven : 'maven'
	}
	
	stages{
		stage('Build'){
				sh 'mvn clean compile'
		}
		stage('Test'){
				sh 'mvn test'	
		}
		stage('Package'){
				sh 'mvn package'	
		}
	}
	
	post{
		success{
				echo 'success'
		}
		failure{
				echo 'fail'
		}
	     }
}

			